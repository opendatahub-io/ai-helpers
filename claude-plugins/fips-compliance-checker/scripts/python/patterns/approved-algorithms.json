      "HKDF": {
        "fips_approved": true,
        "approved_hmac": ["HMAC-SHA256", "HMAC-SHA384", "HMAC-SHA512"]
      },
      "KBKDF": {
        "fips_approved": true,
        "note": "Key-based KDF in Counter Mode"
      }
    },
    "prohibited": {
      "scrypt": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "Argon2": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "bcrypt": {"severity": "CRITICAL", "reason": "Not FIPS approved"}
    }
  },
  "random_number_generation": {
    "approved": {
      "secrets_module": {
        "fips_approved": true,
        "note": "Uses system CSPRNG (os.urandom) which uses /dev/urandom"
      },
      "os_urandom": {
        "fips_approved": true,
        "note": "System CSPRNG, FIPS-approved when system is in FIPS mode"
      },
      "SystemRandom": {
        "fips_approved": true,
        "note": "Uses os.urandom internally"
      }
    },
    "prohibited": {
      "random_module": {
        "severity": "HIGH",
        "reason": "Mersenne Twister, not cryptographically secure",
        "replacement": "secrets module"
      }
    }
  },
  "message_authentication": {
    "approved": {
      "HMAC-SHA256": {"fips_approved": true, "min_key_bits": 128},
      "HMAC-SHA384": {"fips_approved": true, "min_key_bits": 128},
      "HMAC-SHA512": {"fips_approved": true, "min_key_bits": 128},
      "CMAC-AES": {"fips_approved": true, "min_key_bits": 128},
      "GMAC": {"fips_approved": true, "min_key_bits": 128}
