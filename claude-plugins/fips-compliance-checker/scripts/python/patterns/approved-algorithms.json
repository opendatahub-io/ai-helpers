      "AES-256-CCM": {"min_key_bits": 256, "fips_approved": true, "aead": true}
    },
    "deprecated": {
      "3DES": {
        "severity": "HIGH",
        "reason": "Deprecated, 112-bit security is insufficient",
        "replacement": "AES-128 or higher"
      },
      "DES": {
        "severity": "CRITICAL",
        "reason": "56-bit key, cryptographically broken",
        "replacement": "AES-128 or higher"
      }
    },
    "prohibited": {
      "RC4": {"severity": "CRITICAL", "reason": "Cryptographically broken"},
      "Blowfish": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "ChaCha20": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "ChaCha20-Poly1305": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "Salsa20": {"severity": "CRITICAL", "reason": "Not FIPS approved"}
    }
  },
  "asymmetric_encryption": {
    "approved": {
      "RSA": {
        "min_key_bits": 2048,
        "recommended_key_bits": 3072,
        "fips_approved": true,
        "padding_modes": ["OAEP", "PSS"]
      },
      "ECDH": {
        "min_key_bits": 256,
        "fips_approved": true,
        "approved_curves": ["P-256", "P-384", "P-521"]
      },
      "ECDSA": {
        "min_key_bits": 256,
        "fips_approved": true,
        "approved_curves": ["P-256", "P-384", "P-521"]
      }
    },
    "deprecated": {
      "RSA-1024": {
        "severity": "HIGH",
        "reason": "Key length insufficient (minimum 2048 bits required)"
      }
    },
    "prohibited": {
      "Curve25519": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "Ed25519": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
