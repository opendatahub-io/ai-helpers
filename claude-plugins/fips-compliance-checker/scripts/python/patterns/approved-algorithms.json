{
  "hash_algorithms": {
    "approved": {
      "SHA-224": {"min_output_bits": 224, "fips_approved": true},
      "SHA-256": {"min_output_bits": 256, "fips_approved": true},
      "SHA-384": {"min_output_bits": 384, "fips_approved": true},
      "SHA-512": {"min_output_bits": 512, "fips_approved": true},
      "SHA-512/224": {"min_output_bits": 224, "fips_approved": true},
      "SHA-512/256": {"min_output_bits": 256, "fips_approved": true},
      "SHA3-224": {"min_output_bits": 224, "fips_approved": true},
      "SHA3-256": {"min_output_bits": 256, "fips_approved": true},
      "SHA3-384": {"min_output_bits": 384, "fips_approved": true},
      "SHA3-512": {"min_output_bits": 512, "fips_approved": true}
    },
    "deprecated": {
      "MD5": {
        "severity": "HIGH",
        "reason": "Cryptographically broken, not FIPS approved",
        "allowed_use_case": "Non-security checksums with usedforsecurity=False"
      },
      "SHA-1": {
        "severity": "HIGH",
        "reason": "Deprecated for digital signatures and MACs",
        "allowed_use_case": "HMAC-SHA1 only, not for new applications"
      }
    },
    "prohibited": {
      "BLAKE2": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "BLAKE3": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "BLAKE2b": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "BLAKE2s": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "xxHash": {"severity": "CRITICAL", "reason": "Not FIPS approved"},
      "MurmurHash": {"severity": "CRITICAL", "reason": "Not FIPS approved"}
    }
  },
  "symmetric_encryption": {
    "approved": {
      "AES-128-CBC": {"min_key_bits": 128, "fips_approved": true},
      "AES-192-CBC": {"min_key_bits": 192, "fips_approved": true},
      "AES-256-CBC": {"min_key_bits": 256, "fips_approved": true},
      "AES-128-GCM": {"min_key_bits": 128, "fips_approved": true, "aead": true},
      "AES-192-GCM": {"min_key_bits": 192, "fips_approved": true, "aead": true},
      "AES-256-GCM": {"min_key_bits": 256, "fips_approved": true, "aead": true},
      "AES-128-CCM": {"min_key_bits": 128, "fips_approved": true, "aead": true},
